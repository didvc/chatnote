---
import Layout from "../layouts/Layout.astro";
import { config } from "../config";

if (!config.require_password || Astro.locals.user) return Astro.redirect("/");
const error = Astro.url.searchParams.get("error") || "";
---

<Layout title="register · chatnote">
  <div class="auth">
    <div class="card">
      <h2 style="margin:0">create account</h2>
      {error && <p class="error">{error}</p>}
      <form method="post" action="/api/auth/register">
        <div><label>username</label><input name="username" autocomplete="username" required /></div>
        <div><label>password (min 6 chars)</label><input name="password" type="password" autocomplete="new-password" required /></div>
        <button class="btn" type="submit" style="width:100%">register</button>
      </form>
      <p class="muted">already have one? <a href="/login">log in</a></p>
    </div>
  </div>
</Layout>
